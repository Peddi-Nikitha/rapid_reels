rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'admin';
    }
    
    // ==================== USERS COLLECTION ====================
    match /users/{userId} {
      // Users can read their own data
      allow read: if isOwner(userId);
      
      // Users can create/update their own document
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      
      // Users can read public provider data (if userType is provider)
      allow read: if resource.data.userType == 'provider' && resource.data.isActive == true;
      
      // Admin can read/write any user
      allow read, write: if isAdmin();
      
      // Wallet subcollection
      match /wallet/{walletDoc} {
        allow read, write: if isOwner(userId);
      }
      
      // Offer usage subcollection
      match /offer_usage/{offerId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ==================== PROVIDERS COLLECTION ====================
    match /providers/{providerId} {
      // Anyone can read active, verified providers
      allow read: if resource.data.isActive == true;
      
      // Provider can read/write their own data
      allow read, write: if isOwner(providerId);
      
      // Admin can read/write any provider
      allow read, write: if isAdmin();
    }
    
    // ==================== BOOKINGS COLLECTION ====================
    match /bookings/{bookingId} {
      // Customer can read their bookings
      allow read: if isOwner(resource.data.customerId);
      
      // Provider can read their bookings
      allow read: if isOwner(resource.data.providerId);
      
      // Customer can create bookings
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      
      // Customer can update their bookings (cancel, etc.)
      allow update: if isOwner(resource.data.customerId);
      
      // Provider can update their bookings (accept, update status, etc.)
      allow update: if isOwner(resource.data.providerId);
      
      // Admin can read/write any booking
      allow read, write: if isAdmin();
    }
    
    // ==================== REELS COLLECTION ====================
    match /reels/{reelId} {
      // Customer can read their reels
      allow read: if isOwner(resource.data.customerId);
      
      // Provider can read reels for their bookings
      allow read: if isOwner(resource.data.providerId);
      
      // Public reels can be read by anyone
      allow read: if resource.data.isPublic == true && resource.data.status == 'delivered';
      
      // Provider can create/update reels for their bookings
      allow create: if isAuthenticated() && request.resource.data.providerId == request.auth.uid;
      allow update: if isOwner(resource.data.providerId);
      
      // Admin can read/write any reel
      allow read, write: if isAdmin();
    }
    
    // ==================== REVIEWS COLLECTION ====================
    match /reviews/{reviewId} {
      // Anyone can read approved, public reviews
      allow read: if resource.data.status == 'approved' && resource.data.isPublic == true;
      
      // Customer can read their reviews
      allow read: if isOwner(resource.data.customerId);
      
      // Provider can read reviews about them
      allow read: if isOwner(resource.data.providerId);
      
      // Customer can create reviews for their bookings
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      
      // Provider can respond to reviews
      allow update: if isOwner(resource.data.providerId) && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['response', 'respondedAt']);
      
      // Admin can read/write any review
      allow read, write: if isAdmin();
    }
    
    // ==================== REFERRALS COLLECTION ====================
    match /referrals/{referralId} {
      // User can read their referrals (as referrer or referred)
      allow read: if isOwner(resource.data.referrerId) || isOwner(resource.data.referredId);
      
      // System can create referrals (via Cloud Functions or authenticated users)
      allow create: if isAuthenticated();
      
      // Admin can read/write any referral
      allow read, write: if isAdmin();
    }
    
    // ==================== WALLET TRANSACTIONS COLLECTION ====================
    match /wallet_transactions/{transactionId} {
      // User can only read their own transactions
      allow read: if isOwner(resource.data.userId);
      
      // System can create transactions (via Cloud Functions)
      allow create: if isAuthenticated();
      
      // Admin can read/write any transaction
      allow read, write: if isAdmin();
    }
    
    // ==================== NOTIFICATIONS COLLECTION ====================
    match /notifications/{notificationId} {
      // User can only read their own notifications
      allow read: if isOwner(resource.data.userId);
      
      // System can create notifications (via Cloud Functions)
      allow create: if isAuthenticated();
      
      // User can update their notifications (mark as read)
      allow update: if isOwner(resource.data.userId) && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      
      // Admin can read/write any notification
      allow read, write: if isAdmin();
    }
    
    // ==================== OFFERS COLLECTION ====================
    match /offers/{offerId} {
      // Anyone can read active, public offers
      allow read: if resource.data.isActive == true && resource.data.isPublic == true;
      
      // Admin can read/write any offer
      allow read, write: if isAdmin();
    }
    
    // ==================== LIVE EVENTS COLLECTION ====================
    match /live_events/{bookingId} {
      // Customer can read their live events
      allow read: if isOwner(resource.data.customerId);
      
      // Provider can read/write their live events
      allow read, write: if isOwner(resource.data.providerId);
      
      // Admin can read/write any live event
      allow read, write: if isAdmin();
    }
    
    // ==================== ADMIN ANALYTICS COLLECTION ====================
    match /admin_analytics/{date} {
      // Only admin can access
      allow read, write: if isAdmin();
    }
    
    // ==================== SUPPORT TICKETS COLLECTION ====================
    match /support_tickets/{ticketId} {
      // User can read their own tickets
      allow read: if isOwner(resource.data.userId);
      
      // User can create tickets
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // User can update their tickets (add messages)
      allow update: if isOwner(resource.data.userId);
      
      // Admin can read/write any ticket
      allow read, write: if isAdmin();
    }
  }
}

